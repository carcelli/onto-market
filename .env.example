# onto-market environment configuration
# Copy to .env and fill in your keys:  cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────
# Options: grok | openai | gemini | claude | local
LLM_PROVIDER=grok

# xAI / Grok (default provider)
XAI_API_KEY=
GROK_MODEL=grok-4

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini (optional)
GOOGLE_API_KEY=

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=

# Local Ollama (optional)
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=gpt-oss:20b

# ── Data & Memory ─────────────────────────────────────────────────────────
DATABASE_PATH=data/memory.db

# Zep Cloud graph memory (Phase 2)
ZEP_API_KEY=

# ── Research APIs ─────────────────────────────────────────────────────────
TAVILY_API_KEY=
NEWSAPI_API_KEY=

# ── Polymarket / Polygon ──────────────────────────────────────────────────
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com
CLOB_API_URL=https://clob.polymarket.com
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
CHAIN_ID=137
FUNDER_ADDRESS=

# ── Trading ───────────────────────────────────────────────────────────────
SAFE_MODE=true

# ── Swarm Simulation ─────────────────────────────────────────────────────
SWARM_SIZE=5000
SWARM_ROUNDS=5
SWARM_ANALYST_FRACTION=0.03
SWARM_CONVERGENCE_THRESHOLD=0.02

# ── Decision Thresholds ──────────────────────────────────────────────────
MIN_EDGE=0.03
MIN_VOLUME=5000
MIN_KELLY=0.01

# ── ML Research ──────────────────────────────────────────────────────────
USE_ML_PRIOR=false
ML_PRIOR_WEIGHT=0.3
ML_ARTIFACT_DIR=data/ml_artifacts
ML_TRAINING_MODE=sklearn
ML_TRAINING_TIMEOUT=0
ML_MAX_VRAM_MB=3500
ML_MAX_AGE_DAYS=90
